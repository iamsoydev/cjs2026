[sub_resource type="Resource" id="Resource_pqkdh"]
script = ExtResource("3_n7pxa")
text = "Tweet"
metadata/_custom_type_script = "uid://ctkgw6ik2sd35"

[sub_resource type="Resource" id="Resource_vrewo"]
