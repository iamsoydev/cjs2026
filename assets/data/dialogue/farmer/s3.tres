[sub_resource type="Resource" id="Resource_hjaar"]
script = ExtResource("1_gsxpb")
text = "But the odd thing is... I saw a pair of small tracks. "
metadata/_custom_type_script = "uid://ctkgw6ik2sd35"

[sub_resource type="Resource" id="Resource_wip50"]
script = ExtResource("1_gsxpb")
text = "Coming from the wheat fields..."
metadata/_custom_type_script = "uid://ctkgw6ik2sd35"

[sub_resource type="Resource" id="Resource_pybbb"]
script = ExtResource("1_gsxpb")
text = "They must have had an accomplice. "
metadata/_custom_type_script = "uid://ctkgw6ik2sd35"

[sub_resource type="Resource" id="Resource_lvh1r"]
script = ExtResource("1_gsxpb")
text = "Question the calfs to see what you can find."
